{
  "name": "obsidian-clone",
  "version": "0.1.0",
  "description": "A feature-rich Obsidian-like markdown editor",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,main,electron -c cyan,yellow,green \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.node.json -w --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 && sleep 5 && nodemon --watch dist-electron/electron/main.js --exec 'electron .'",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.1",
    "@codemirror/commands": "^6.6.2",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.35.3",
    "@lezer/highlight": "^1.2.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^3.6.0",
    "codemirror": "^6.0.1",
    "diff": "^8.0.4",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.35.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "nodemon": "^3.1.7",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
